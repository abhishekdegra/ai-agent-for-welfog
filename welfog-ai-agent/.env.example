# Copy to .env and fill in your keys:
#   cp .env.example .env

# Hugging Face (sentence-transformers / KB embeddings)
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=

# Local Ollama (optional)
LLAMA_API_URL=http://localhost:11434/api/generate
LLAMA_MODEL=llama3

# LLM provider chain (comma-separated): groq,openai,gemini,deepseek
# First provider is tried; on failure the next is used automatically.
LLM_PROVIDER_ORDER=groq,openai,gemini,deepseek
LLM_MAX_PROVIDERS=4
LLM_CLASSIFIER_MAX_PROVIDERS=4
LLM_ROUTING_MAX_PROVIDERS=4
STRICT_AI_INTENT_ROUTING=1
STRICT_LLM_FAILSAFE=1

# Groq Cloud (first in chain)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# Optional xAI Grok (legacy "grok" slot in LLM_PROVIDER_ORDER)
GROK_API_KEY=
GROK_MODEL=grok-3-mini

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Flask app
DEBUG=True
PORT=5000
FLASK_SECRET_KEY=change-me-to-a-long-random-string
SECRET_KEY=change-me-to-a-long-random-string

# Database (SQLite paths relative to support/)
DATABASE_URL=sqlite:///welfog_v2.db
DATABASE_URL_HISTORY=sqlite:///welfog_history.db

# Backend API (optional)
BACKEND_API_URL=http://localhost:8000/api

# Timeouts (seconds)
AI_TIMEOUT=20
CHAT_MAX_SECONDS=75

# OpenSearch product catalog
OPENSEARCH_URL=
OPENSEARCH_USER=
OPENSEARCH_PASS=

# Embeddings (set 1 to skip sentence-transformers load)
DISABLE_EMBEDDINGS=0

# Encoding
PYTHONIOENCODING=utf-8
