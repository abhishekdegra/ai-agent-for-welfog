# Copy to .env in this same folder (support/):
#   copy .env.example .env

# Hugging Face (sentence-transformers / KB embeddings)
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=

# Local Ollama (optional)
LLAMA_API_URL=http://localhost:11434/api/generate
LLAMA_MODEL=llama3

# LLM provider chain (comma-separated): groq,openai,gemini,deepseek
# First provider is tried; on failure the next is used automatically.
LLM_PROVIDER_ORDER=groq,openai,gemini,deepseek
LLM_MAX_PROVIDERS=4
LLM_CLASSIFIER_MAX_PROVIDERS=4
LLM_ROUTING_MAX_PROVIDERS=4
STRICT_AI_INTENT_ROUTING=1
STRICT_LLM_FAILSAFE=1

# Groq Cloud (first in chain)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# Optional xAI Grok (legacy "grok" slot in LLM_PROVIDER_ORDER)
GROK_API_KEY=
GROK_MODEL=grok-3-mini

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Flask app
DEBUG=True
PORT=5000
FLASK_SECRET_KEY=change-me-to-a-long-random-string
SECRET_KEY=change-me-to-a-long-random-string

# Database (SQLite admin panel — lives in support/)
DATABASE_URL=sqlite:///welfog_v2.db

# MySQL (XAMPP) — chat history (sidebar + messages)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=welfog_ai
MYSQL_CONNECT_TIMEOUT=10
MYSQL_READ_TIMEOUT=30
MYSQL_WRITE_TIMEOUT=30
MYSQL_COLLATION=utf8mb4_unicode_ci

# Backend API (optional)
BACKEND_API_URL=http://localhost:8000/api

# Timeouts (seconds)
AI_TIMEOUT=20
CHAT_MAX_SECONDS=75

# OpenSearch product catalog
OPENSEARCH_URL=
OPENSEARCH_USER=
OPENSEARCH_PASS=

# Qdrant knowledge vectors (docker compose up -d → welfog-qdrant on :6333/:6334)
QDRANT_ENABLED=1
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=welfog_knowledge_chunks
QDRANT_VECTOR_SIZE=1536
QDRANT_DISTANCE=Cosine
QDRANT_TIMEOUT_SEC=5

# Knowledge embedding indexer (Step 5)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
KNOWLEDGE_EMBED_BATCH_SIZE=32
OPENAI_EMBED_TIMEOUT_SEC=60

# Knowledge retrieval (Step 6 — Qdrant semantic search for KB intent)
KB_RETRIEVAL_BACKEND=qdrant
KNOWLEDGE_RETRIEVAL_TOP_K=8
KNOWLEDGE_RETRIEVAL_MIN_SCORE=0.22

# Knowledge answer generation (Step 7)
KNOWLEDGE_ANSWER_TOP_K=12

# Knowledge re-indexing (Step 8)
KNOWLEDGE_CHUNK_SIZE=900
KNOWLEDGE_CHUNK_OVERLAP=120

# RAG pipeline debug (observability only — no behavior change)
RAG_DEBUG=false

# Embeddings (set 1 to skip sentence-transformers load)
DISABLE_EMBEDDINGS=0

# Encoding
PYTHONIOENCODING=utf-8
