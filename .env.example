# =============================================================================
# Welfog support — environment template (SAFE TO COMMIT)
# =============================================================================
# Clone / teammate setup:
#   1. copy .env.example .env
#   2. Fill secrets (or ask teammate to send a real `.env` privately — never via git)
#   3. Run: python app.py
#
# NEVER commit support/.env — it is gitignored. Push only this .env.example.
# =============================================================================

# Hugging Face (sentence-transformers / KB embeddings)
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=

# Local Ollama (optional)
LLAMA_API_URL=http://localhost:11434/api/generate
LLAMA_MODEL=llama3

# LLM provider chain (comma-separated): openai,gemini,deepseek,groq
# First provider is tried; on failure the next is used automatically.
LLM_PROVIDER_ORDER=openai,gemini,deepseek,groq
LLM_MAX_PROVIDERS=4
LLM_CLASSIFIER_MAX_PROVIDERS=4
LLM_ROUTING_MAX_PROVIDERS=4
STRICT_AI_INTENT_ROUTING=1
STRICT_LLM_FAILSAFE=1

# --- Secrets: paste real keys here (or receive via private .env) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# Optional xAI Grok (legacy "grok" slot in LLM_PROVIDER_ORDER)
GROK_API_KEY=
GROK_MODEL=grok-3-mini

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Flask app
DEBUG=True
PORT=5000
FLASK_PORT=5000
FLASK_SECRET_KEY=change-me-to-a-long-random-string
SECRET_KEY=change-me-to-a-long-random-string

# Database (SQLite admin panel — always resolved under support/, not Flask instance/)
# Prefer relative name; app pins it to support/welfog_v2.db
DATABASE_URL=sqlite:///welfog_v2.db

# MySQL (XAMPP) — chat history (sidebar + messages)
# All MYSQL_* keys are REQUIRED by the app (MYSQL_PASSWORD may be empty for local root).
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=welfog_ai
MYSQL_CONNECT_TIMEOUT=10
MYSQL_READ_TIMEOUT=30
MYSQL_WRITE_TIMEOUT=30
MYSQL_COLLATION=utf8mb4_unicode_ci
# Optional: MYSQL_DATA_DIR=C:/xampp/mysql/data/welfog_ai

# Backend API (optional)
BACKEND_API_URL=http://localhost:8000/api

# Timeouts (seconds)
AI_TIMEOUT=20
CHAT_ASYNC_HANDLER=0
CHAT_MAX_SECONDS=45
AI_ROUTE_TIMEOUT=8
CHAT_MAX_LLM_CALLS=5
LLM_REWRITE_TIMEOUT_SEC=4
LLM_REWRITE_MAX_PROVIDERS=1
# Fast OOD/chitchat decline (second LLM only when Brain left scope_reply empty)
OOD_AI_TIMEOUT_SEC=2.5
OOD_AI_MAX_PROVIDERS=1
CHITCHAT_AI_TIMEOUT_SEC=2.5
CHITCHAT_AI_MAX_PROVIDERS=1
CHITCHAT_AI_PREFER_PROVIDER=groq
SCOPE_AI_TIMEOUT_SEC=2.5

# OpenSearch product catalog (URL + credentials — never hardcode in Python)
OPENSEARCH_URL=
OPENSEARCH_USER=
OPENSEARCH_PASS=

# Qdrant knowledge vectors (docker compose up -d → welfog-qdrant on :6333/:6334)
QDRANT_ENABLED=1
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=welfog_knowledge_chunks
QDRANT_VECTOR_SIZE=1536
QDRANT_DISTANCE=Cosine
QDRANT_TIMEOUT_SEC=5

# Knowledge embedding indexer (Step 5)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
KNOWLEDGE_EMBED_BATCH_SIZE=32
OPENAI_EMBED_TIMEOUT_SEC=5

# Knowledge retrieval (Step 6 — Qdrant semantic search for KB intent)
KB_RETRIEVAL_BACKEND=qdrant
KNOWLEDGE_RETRIEVAL_TOP_K=8
KNOWLEDGE_RETRIEVAL_MIN_SCORE=0.22
KB_DIRECT_MIN_SCORE=0.16
KB_ANSWER_MIN_CONFIDENCE=0.18
KB_SEMANTIC_MIN_SCORE=0.16
RETRIEVAL_TRANSLATE_TIMEOUT_SEC=1.2
ENABLE_KB_AI_FOCUS_ANSWER=0

# Knowledge answer generation (Step 7)
KNOWLEDGE_ANSWER_TOP_K=12

# Knowledge re-indexing (Step 8)
KNOWLEDGE_CHUNK_SIZE=900
KNOWLEDGE_CHUNK_OVERLAP=120

# RAG pipeline debug (observability only — no behavior change)
RAG_DEBUG=false

# Embeddings (set 1 to skip sentence-transformers load)
DISABLE_EMBEDDINGS=0

# Encoding
PYTHONIOENCODING=utf-8
